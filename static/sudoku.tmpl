    <script type="application/javascript">

    globalThis.sudokuPreloaderComplete = false

    function drawSudokuPreloader() {
        const canvas = document.getElementById("sudoku-preloader-canvas")
        if (!canvas) {
            globalThis.sudokuPreloaderComplete = true
            return
        }

        const ctx = canvas.getContext("2d")
        const size = 750
        const block = size / 9
        const board = [
            [5, 3, 4, 6, 7, 8, 9, 1, 2],
            [6, 7, 2, 1, 9, 5, 3, 4, 8],
            [1, 9, 8, 3, 4, 2, 5, 6, 7],
            [8, 5, 9, 7, 6, 1, 4, 2, 3],
            [4, 2, 6, 8, 5, 3, 7, 9, 1],
            [7, 1, 3, 9, 2, 4, 8, 5, 6],
            [9, 6, 1, 5, 3, 7, 2, 8, 4],
            [2, 8, 7, 4, 1, 9, 6, 3, 5],
            [3, 4, 5, 2, 8, 6, 1, 7, 9],
        ]
        const cellOrder = []
        for (let row = 0; row < 9; row += 1) {
            for (let col = 0; col < 9; col += 1) {
                cellOrder.push([row, col])
            }
        }
        for (let index = cellOrder.length - 1; index > 0; index -= 1) {
            const swapIndex = Math.floor(Math.random() * (index + 1))
            const current = cellOrder[index]
            cellOrder[index] = cellOrder[swapIndex]
            cellOrder[swapIndex] = current
        }
        let visible = 0

        function drawGrid() {
            ctx.strokeStyle = "rgb(0, 0, 0)"
            for (let index = 0; index <= 9; index += 1) {
                ctx.lineWidth = index % 3 === 0 ? 4 : 1
                const position = index * block
                ctx.beginPath()
                ctx.moveTo(position, 0)
                ctx.lineTo(position, size)
                ctx.stroke()
                ctx.beginPath()
                ctx.moveTo(0, position)
                ctx.lineTo(size, position)
                ctx.stroke()
            }
        }

        function drawFrame() {
            ctx.fillStyle = "rgb(252, 248, 235)"
            ctx.fillRect(0, 0, size, size)
            ctx.fillStyle = "rgb(0, 0, 0)"
            ctx.font = "50px Arial, sans-serif"
            ctx.textAlign = "center"
            ctx.textBaseline = "middle"

            for (let index = 0; index < visible; index += 1) {
                const [row, col] = cellOrder[index]
                ctx.fillText(String(board[row][col]), col * block + block / 2, row * block + block / 2)
            }

            drawGrid()
        }

        function advance() {
            drawFrame()
            if (visible < 81) {
                visible += 1
                window.setTimeout(advance, 24)
            } else {
                globalThis.sudokuPreloaderComplete = true
            }
        }

        advance()
    }

    drawSudokuPreloader()

